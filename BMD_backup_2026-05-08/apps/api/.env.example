# =============================================================================
# BMD — API · Variables d'environnement
# =============================================================================
# Copie ce fichier vers `.env` (dev) puis ajuste les valeurs.
#
# Convention :
#  - Variables marquées REQUIRED → l'app crash au démarrage si absentes
#  - Variables marquées OPTIONAL → fallback automatique si vides
#  - 🔒 = à conserver en secret manager en prod (jamais committer)
# =============================================================================

# === Core ====================================================================
NODE_ENV=development
DATABASE_URL="postgres://bmd:bmd@localhost:5433/bmd_dev"   # REQUIRED 🔒
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# === JWT (sessions) ==========================================================
# REQUIRED — au moins 32 caractères. Génère avec : openssl rand -hex 32
JWT_SECRET=development-secret-change-me-in-prod-please-32chars   # 🔒
JWT_EXPIRES_IN=30d

# === OTP (codes login sans mot de passe) =====================================
# REQUIRED — pepper utilisé pour hasher les codes avant stockage (argon2)
OTP_PEPPER=development-pepper-change-me-min-8-chars   # 🔒
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
# Anti-bombing : nb max d'OTP demandés par contact / heure
OTP_RATE_LIMIT_PER_HOUR=5

# Mode de livraison OTP :
#   console (dev) | twilio | whatsapp | resend | auto
# "auto" choisit le canal selon le type de contact :
#   PHONE → twilio si configuré, sinon whatsapp, sinon console
#   EMAIL → resend si configuré, sinon console
OTP_DELIVERY_MODE=console

# === Twilio (SMS) ============================================================
# https://www.twilio.com/console — laisser vide en dev
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=          # 🔒
TWILIO_FROM_NUMBER=         # ex: +14155551234
# Sprint AC · Twilio Verify Service SID (commence par "VA").
# Si défini → l'OTP est géré par Twilio Verify (anti-fraude built-in :
# rate limiting, abuse detection, attempts tracking, multi-channel auto).
# Sinon → fallback sur SMS direct via Messages.json + vérif locale BDD.
TWILIO_VERIFY_SERVICE_SID=

# === Resend (emails transactionnels) =========================================
# https://resend.com — alternative simple à Postmark/SendGrid
RESEND_API_KEY=             # 🔒
RESEND_FROM_EMAIL=noreply@backmesdo.com
RESEND_FROM_NAME=BMD

# === WhatsApp Cloud API (Meta) ===============================================
# https://developers.facebook.com/docs/whatsapp/cloud-api
# Le template doit être pré-approuvé par Meta (variable {{1}} = code OTP)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=                  # 🔒
# Numéro public (E.164 sans le +) pour le bouton « Se connecter avec WhatsApp »
# (spec §7.2). Utilisé pour wa.me/{numero}?text=BMD-LOGIN-XXXX.
# Si vide → bouton WhatsApp masqué côté UI.
WHATSAPP_BUSINESS_NUMBER=               # ex: 33612345678
WHATSAPP_OTP_TEMPLATE=bmd_otp_v1
# Token de vérification du webhook (à renseigner côté Meta App Dashboard)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=          # 🔒
# Secret applicatif Meta — vérifie la signature X-Hub-Signature-256
WHATSAPP_APP_SECRET=                    # 🔒

# === SSO Google (optionnel) ==================================================
# 1. https://console.cloud.google.com/apis/credentials
# 2. Crée un OAuth 2.0 Client ID type "Application Web"
# 3. Origines JS autorisées : http://localhost:3000 (+ domaine prod)
# 4. URI de redirection : http://localhost:3000/auth/google/callback
# Vide → bouton SSO Google masqué côté UI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=                   # 🔒

# URL publique du front (pour redirects OAuth, Stripe Checkout, magic links…)
WEB_BASE_URL=http://localhost:3000

# === SSO Apple (spec §7.2) ===================================================
# https://developer.apple.com/account/resources/identifiers
# 1. Crée un Services ID (ex: app.bmd.web) → APPLE_CLIENT_ID
# 2. Récupère ton Team ID (10 caractères) → APPLE_TEAM_ID
# 3. Crée une clé "Sign in with Apple" → APPLE_KEY_ID + télécharge le .p8
# 4. Colle le contenu du .p8 (avec BEGIN/END et \n encodés) → APPLE_PRIVATE_KEY
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=                      # 🔒

# === Web Push notifications (spec §8.5) ======================================
# Génère les clés en local : npx -y web-push generate-vapid-keys
# Vide → push web désactivé (in-app + email continuent à fonctionner).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                      # 🔒
VAPID_SUBJECT=mailto:noreply@backmesdo.com

# === OCR providers (spec §3.8) ===============================================
# auto : Mindee si MINDEE_API_KEY > OpenAI Vision si OPENAI_API_KEY > Tesseract local
OCR_PROVIDER=auto
# https://platform.mindee.com — gratuit jusqu'à 250 pages/mois
MINDEE_API_KEY=                         # 🔒
# Sprint AC · Type de document Mindee : "auto" (défaut) | "invoice" | "receipt"
# - "invoice" → modèle Invoice v4 (factures pro avec TVA, IBAN, n° facture…)
# - "receipt" → modèle Receipts v5 (tickets de caisse simples)
# - "auto"    → PDF → Invoice ; image → Invoice avec fallback Receipt si échec
MINDEE_DOC_TYPE=auto
# https://platform.openai.com — gpt-4o-mini ~ 0.001$/image
OPENAI_API_KEY=                         # 🔒
OPENAI_VISION_MODEL=gpt-4o-mini

# === Whisper API (transcription voix → texte, spec §3.8) =====================
# https://whisper-api.com — saisie vocale d'une dépense au micro
# Si vide → fallback sur API Web Speech navigateur (qualité moindre)
WHISPER_API_KEY=                        # 🔒
WHISPER_API_URL=https://transcribe.whisperapi.com

# === Vault chiffrement moyens de paiement (spec §9.1) ========================
# Génère une clé AES-256 : openssl rand -base64 32
# Vide → fonctionnalité "moyens de paiement sauvegardés" désactivée.
# ⚠️ EN PROD : conserve cette clé dans un secret manager (AWS KMS, Vault…)
# ⚠️ Si tu la perds, les méthodes déjà chiffrées deviennent illisibles.
PAYMENT_VAULT_KEY=                      # 🔒

# === FX Provider (spec §4) ===================================================
# Open Exchange Rates : compte gratuit https://openexchangerates.org/signup/free
# 1000 req/mois suffisent (refresh horaire = ~720/mois).
# Vide → fallback automatique sur exchangerate.host (gratuit, sans clé).
OPENEXCHANGERATES_KEY=                  # 🔒

# === Cache distribué (optionnel — multi-instance) ============================
# Si REDIS_URL défini ET ioredis installé, lib/cache.ts l'utilise pour
# sessions / throttling / hot queries. Sinon → fallback in-memory mono-instance.
# Format : redis://[:password@]host:port[/db] ou rediss://… (TLS).
REDIS_URL=                              # 🔒 ex: redis://default:xxx@host:6379

# === Stripe (spec §6.3) ======================================================
# Test : sk_test_xxx + pk_test_xxx ; Prod : sk_live_xxx + pk_live_xxx
# Webhook secret : Dashboard → Developers → Webhooks → "Reveal"
# Vide → flows paiement renvoient un MVP-stub.
STRIPE_SECRET_KEY=                      # 🔒
STRIPE_WEBHOOK_SECRET=                  # 🔒
STRIPE_API_VERSION=2024-10-28.acacia
