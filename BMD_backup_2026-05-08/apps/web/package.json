{
  "name": "@bmd/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "echo 'lint skipped (no eslint config yet)'",
    "typecheck": "tsc --noEmit",
    "i18n:check": "node scripts/check-i18n-coverage.mjs",
    "i18n:check:strict": "node scripts/check-i18n-coverage.mjs --strict --report",
    "i18n:audit": "node scripts/check-no-fr-strings.mjs",
    "i18n:audit:strict": "node scripts/check-no-fr-strings.mjs --strict",
    "test": "npm run i18n:check && npm run i18n:audit"
  },
  "dependencies": {
    "@bmd/shared-types": "*",
    "@simplewebauthn/browser": "^10.0.0",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
