# Copy this file to .env and adjust the values
DATABASE_URL="postgres://bmd:bmd@localhost:5433/bmd_dev"
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# JWT signing — MUST be at least 32 characters in production
JWT_SECRET=development-secret-change-me-in-prod-please-32chars
JWT_EXPIRES_IN=30d

# OTP — pepper used to hash codes before storing
OTP_PEPPER=development-pepper-change-me
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# Anti-bombing : nb max d'OTP demandés par contact / heure
OTP_RATE_LIMIT_PER_HOUR=5

# Mode dev : log les OTP au lieu d'appeler Twilio / WhatsApp
OTP_DELIVERY_MODE=console
# Production: replace with "twilio" / "whatsapp" / "postmark"
