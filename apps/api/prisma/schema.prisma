// Prisma schema · BMD backend
// docs : https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id              String   @id @default(uuid())
  displayName     String
  avatar          String?
  defaultCurrency String   @default("EUR")
  defaultLocale   String   @default("fr")
  isSuperAdmin    Boolean  @default(false)
  suspendedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contacts             UserContact[]
  groupMemberships     GroupMember[]
  expensesPaid         Expense[]              @relation("ExpensePaidBy")
  expenseShares        ExpenseShare[]
  sessions             Session[]
  settlementsFrom      Settlement[]           @relation("SettlementFrom")
  settlementsTo        Settlement[]           @relation("SettlementTo")
  tontineContributions TontineContribution[]
  tontineTurns         TontineTurn[]          @relation("TurnBeneficiary")
  debtSwapParticipations DebtSwapParticipant[]
}

enum ContactType {
  PHONE
  EMAIL
}

model UserContact {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ContactType
  value       String
  isVerified  Boolean     @default(false)
  isPrimary   Boolean     @default(false)
  verifiedAt  DateTime?
  createdAt   DateTime    @default(now())

  @@unique([type, value])
  @@index([userId])
}

model OtpCode {
  id           String      @id @default(uuid())
  contactType  ContactType
  contactValue String
  codeHash     String
  attempts     Int         @default(0)
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime    @default(now())

  @@index([contactType, contactValue, consumedAt])
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  device    String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
}

// ============================================================
// GROUPS
// ============================================================

enum GroupType {
  TONTINE
  COLOC
  TRAVEL
  EVENT
  CLUB
  PARISH
  GENERIC
}

enum MemberRole {
  ADMIN
  TREASURER
  MEMBER
  OBSERVER
}

model Group {
  id              String    @id @default(uuid())
  name            String
  type            GroupType
  defaultCurrency String    @default("EUR")
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  members      GroupMember[]
  expenses     Expense[]
  settlements  Settlement[]
  tontine      Tontine?
  debtSwaps    DebtSwap[]
  splitPresets SplitPreset[]
}

model GroupMember {
  id       String     @id @default(uuid())
  groupId  String
  group    Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  expenseShares ExpenseShare[]

  @@unique([groupId, userId])
  @@index([userId])
}

// ============================================================
// EXPENSES
// ============================================================

enum SplitMode {
  EQUAL
  UNEQUAL
  PERCENTAGE
}

model Expense {
  id          String    @id @default(uuid())
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal   @db.Decimal(14, 4)
  currency    String
  category    String?
  paidById    String
  paidBy      User      @relation("ExpensePaidBy", fields: [paidById], references: [id])
  splitMode   SplitMode @default(EQUAL)
  occurredAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  shares ExpenseShare[]

  @@index([groupId, occurredAt])
}

model ExpenseShare {
  id            String      @id @default(uuid())
  expenseId     String
  expense       Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  groupMemberId String
  groupMember   GroupMember @relation(fields: [groupMemberId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountOwed    Decimal     @db.Decimal(14, 4)

  @@index([expenseId])
  @@index([userId])
}

// ============================================================
// SETTLEMENTS
// ============================================================

enum SettlementStatus {
  PROPOSED
  PAID
  CONFIRMED
  CANCELLED
}

model Settlement {
  id                 String           @id @default(uuid())
  groupId            String
  group              Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUserId         String
  fromUser           User             @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUserId           String
  toUser             User             @relation("SettlementTo", fields: [toUserId], references: [id])
  amount             Decimal          @db.Decimal(14, 4)
  currency           String
  status             SettlementStatus @default(PROPOSED)
  proposedAt         DateTime         @default(now())
  confirmedByPayerAt DateTime?
  confirmedByPayeeAt DateTime?
}

// ============================================================
// TONTINES (M08) — épargne collective rotative
// ============================================================

enum TontineFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum TontineStatus {
  DRAFT       // configurée mais pas encore lancée
  ACTIVE      // en cours
  COMPLETED   // tous les tours réalisés
  CANCELLED
}

enum BeneficiaryOrderMode {
  RANDOM      // ordre tiré au sort à la création
  MANUAL      // ordre défini par l'admin
  AUCTION     // enchères type Hui (à venir)
}

model Tontine {
  id                    String                @id @default(uuid())
  groupId               String                @unique
  group                 Group                 @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contributionAmount    Decimal               @db.Decimal(14, 4)
  currency              String
  frequency             TontineFrequency
  startDate             DateTime
  status                TontineStatus         @default(DRAFT)
  orderMode             BeneficiaryOrderMode  @default(MANUAL)
  centralizedPot        Boolean               @default(true)  // true = cagnotte centralisée, false = paiements directs au bénéficiaire
  notes                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  cancelledAt           DateTime?
  completedAt           DateTime?

  turns TontineTurn[]
}

enum TurnStatus {
  PENDING       // pas encore commencé
  IN_PROGRESS   // ouvert aux cotisations
  DISTRIBUTED   // pot remis au bénéficiaire
  CANCELLED
}

model TontineTurn {
  id              String      @id @default(uuid())
  tontineId       String
  tontine         Tontine     @relation(fields: [tontineId], references: [id], onDelete: Cascade)
  turnNumber      Int
  beneficiaryUserId String
  beneficiary     User        @relation("TurnBeneficiary", fields: [beneficiaryUserId], references: [id])
  dueDate         DateTime
  distributedAt   DateTime?
  status          TurnStatus  @default(PENDING)

  contributions TontineContribution[]

  @@unique([tontineId, turnNumber])
  @@index([beneficiaryUserId])
}

enum ContributionStatus {
  PENDING       // attendue, pas encore versée
  PAID          // l'utilisateur dit avoir payé
  CONFIRMED     // bénéficiaire/admin a confirmé la réception
  MISSED        // n'a pas payé (anti-fraude)
}

model TontineContribution {
  id                String              @id @default(uuid())
  turnId            String
  turn              TontineTurn         @relation(fields: [turnId], references: [id], onDelete: Cascade)
  contributorUserId String
  contributor       User                @relation(fields: [contributorUserId], references: [id])
  amount            Decimal             @db.Decimal(14, 4)
  status            ContributionStatus  @default(PENDING)
  paidAt            DateTime?
  confirmedAt       DateTime?
  paymentMethod     String?             // ex: "Wave", "Lydia", "Cash"
  paymentReference  String?

  @@unique([turnId, contributorUserId])
  @@index([contributorUserId])
}

// ============================================================
// DEBT SWAP (M09) — compensation triangulaire / N-aire
// ============================================================

enum DebtSwapStatus {
  PROPOSED    // proposition active, en attente d'acceptations
  ACCEPTED    // toutes les parties ont accepté → compensation effective
  REJECTED    // au moins une partie a refusé
  EXPIRED     // pas accepté dans les 48h
  CANCELLED   // proposeur a annulé
}

model DebtSwap {
  id            String          @id @default(uuid())
  groupId       String
  group         Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  proposedById  String
  status        DebtSwapStatus  @default(PROPOSED)
  description   String?         // ex: "Simplification de 3 dettes croisées"
  totalSavedAmount Decimal      @db.Decimal(14, 4)  // montant total compensé (combien d'argent évite de circuler)
  expiresAt     DateTime
  createdAt     DateTime        @default(now())
  resolvedAt    DateTime?

  participants DebtSwapParticipant[]
  legs         DebtSwapLeg[]

  @@index([groupId, status])
}

model DebtSwapParticipant {
  id          String          @id @default(uuid())
  swapId      String
  swap        DebtSwap        @relation(fields: [swapId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  acceptedAt  DateTime?       // null = pas encore répondu
  rejectedAt  DateTime?

  @@unique([swapId, userId])
}

// "leg" = un transfert virtuel résultant du swap (qui doit payer combien à qui APRÈS la compensation)
model DebtSwapLeg {
  id           String   @id @default(uuid())
  swapId       String
  swap         DebtSwap @relation(fields: [swapId], references: [id], onDelete: Cascade)
  fromUserId   String
  toUserId     String
  amount       Decimal  @db.Decimal(14, 4)
  currency     String
}

// ============================================================
// SPLIT PRESETS (M10) — modèles de partage réutilisables par groupe
// ============================================================

model SplitPreset {
  id          String   @id @default(uuid())
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String              // ex: "Couple seul", "Comité salle (8 personnes)", "Famille 60% / amis 40%"
  splitMode   SplitMode
  // structure : { participants: [{userId, share}], paidByUserId? }
  // stockée en JSON pour flexibilité
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupId])
}
