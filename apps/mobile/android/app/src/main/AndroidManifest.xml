<?xml version="1.0" encoding="utf-8"?>
<!--
	BMD · Android Manifest

	Permissions justifiées (anti-rejet Google Play) :
	  - INTERNET : nécessaire pour communiquer avec api.backmesdo.com
	  - POST_NOTIFICATIONS (Android 13+) : push notifications BMD
	  - CAMERA : scan de tickets pour OCR
	  - READ_CONTACTS : suggestion d'invitations (avec consentement explicite côté UI)
	  - VIBRATE : feedback haptique sur les actions
	  - WAKE_LOCK : pour les notifications en arrière-plan
	  - USE_BIOMETRIC : Face Unlock / Empreinte (équivalent iOS Face ID/Touch ID)

	App Links autoVerify=true → Google vérifie automatiquement que
	backmesdo.com sert /.well-known/assetlinks.json et active l'ouverture
	directe sans le picker "Compléter avec…".
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ================================================================ -->
    <!-- PERMISSIONS — chacune justifiée dans la Data Safety Form           -->
    <!-- ================================================================ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Caractéristiques requises (matérielles) -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.fingerprint" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="false">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:exported="true">

            <!-- Launcher standard -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- App Links pour backmesdo.com (Android 12+ exige autoVerify) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="backmesdo.com" />
                <data android:scheme="https" android:host="app.backmesdo.com" />
                <data android:scheme="https" android:host="www.backmesdo.com" />
            </intent-filter>

            <!-- Custom scheme `bmd://` pour retours OAuth Apple/Google -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bmd" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Push Notifications via FCM (V132 — câblé + sender backend prêt).
             - default_notification_icon : silhouette monochrome blanche
               (Android exige une icône silhouette depuis Lollipop, sinon
               un carré blanc anonyme est affiché à la place). Le drawable
               vit dans res/drawable/ic_notification.xml.
             - default_notification_color : la couleur d'accent qu'Android
               applique sur cette silhouette + sur la status bar (saffron BMD).
             - default_notification_channel_id : utilisé si le payload FCM ne
               précise pas de channel. Correspond à `bmd_default` créé côté JS
               via push.ensureAndroidChannel(). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="bmd_default" />

    </application>

</manifest>
