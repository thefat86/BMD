# =============================================================================
# BMD — Web (Next.js) · Variables d'environnement
# =============================================================================
# Copie vers `.env.local` (gitignoré par défaut sur Next).
#
# Convention :
#  - Variables NEXT_PUBLIC_* → exposées au client (donc visibles dans le bundle JS)
#  - Variables sans préfixe   → uniquement côté serveur (Server Components, API routes)
# =============================================================================

# === URL de l'API BMD =========================================================
# En dev : laisse commenté. api-client.ts dérive l'URL depuis window.location
# (utile pour tester depuis un mobile sur le LAN — http://192.168.x.x:3000
# appelle automatiquement http://192.168.x.x:4000).
# En prod : décommente avec la vraie URL.
# NEXT_PUBLIC_API_URL=https://api.backmesdo.com

# === Stripe (côté client — Checkout / Stripe.js) =============================
# Test : pk_test_xxx ; Prod : pk_live_xxx
# Cette clé est PUBLIQUE et peut être committée — c'est la clé "publishable".
# La clé secrète (sk_*) reste côté API uniquement (apps/api/.env).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === Site canonique ==========================================================
# Utilisé pour les liens absolus (Open Graph, partage social, sitemap…).
NEXT_PUBLIC_SITE_URL=https://www.backmesdo.com
