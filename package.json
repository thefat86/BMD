{
  "name": "bmd",
  "version": "0.1.0",
  "private": true,
  "description": "BMD · Back Mes Do · monorepo (backend + web + shared)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:up": "docker compose up -d db",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:reset": "cd apps/api && npx prisma migrate reset --force"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
